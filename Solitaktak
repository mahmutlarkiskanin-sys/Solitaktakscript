local function AddB(txt, callback, color)
    local b = Instance.new("TextButton", ScrollFrame)
    b.Size, b.BackgroundColor3 = UDim2.new(0.9, 0, 0, 50)
    b.Text, b.TextColor3, b.Font, b.TextSize = txt, Color3.fromRGB(255, 255, 255), Enum.Font.SourceSansBold, 15
    Instance.new("UICorner", b)
    local act = false
    b.MouseButton1Click:Connect(function()
        act = not act
        if not color then b.BackgroundColor3 = act and Color3.fromRGB(0, 150, 80) or Color3.fromRGB(35, 35, 35) end
        callback(act)
    end)
end

