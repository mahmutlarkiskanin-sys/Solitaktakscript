ScrollFrame.Position = UDim2.new(0, 5, 0, 50)
ScrollFrame.BackgroundTransparency = 1
ScrollFrame.ScrollBarThickness = 8
ScrollFrame.ScrollBarImageColor3 = Color3.fromRGB(0, 255, 150)
ScrollFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
ScrollFrame.AutomaticCanvasSize = Enum.AutomaticSize.Y

local UIList = Instance.new("UIListLayout", ScrollFrame)
UIList.Padding, UIList.HorizontalAlignment = UDim.new(0, 10), Enum.HorizontalAlignment.Center

local function AddB(txt, callback, color)
    local b = Instance.new("TextButton", ScrollFrame)
    b.Size, b.BackgroundColor3 = UDim2.new(0.9, 0, 0, 50), color or Color3.fromRGB(35, 35, 35)
    b.Text, b.TextColor3, b.Font, b.TextSize = txt, Color3.fromRGB(255, 255, 255), Enum.Font.SourceSansBold, 16
    Instance.new("UICorner", b)
    local act = false
    b.MouseButton1Click:Connect(function()
        act = not act
        if not color then b.BackgroundColor3 = act and Color3.fromRGB(0, 150, 80) or Color3.fromRGB(35, 35, 35) end
        callback(act)
    end)
end

AddB("TELEPORT SPAWN", function()
    if savedCFrame and Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
        Player.Character.HumanoidRootPart.CFrame = savedCFrame
    end
end, Color3.fromRGB(0, 100, 200))

AddB("FPS OPTIMIZER", function(s) OptimizeFPS(s) end)
AddB("ESP BOXES", function(s) espActive = s end)
AddB("ANTI RAGDOLL", function(s) antiRagdollActive = s end)
AddB("SPEED 22 BYPASS", function(s) speedActive = s end)
AddB("INF JUMP", function(s) infJumpActive = s end)

local BlockBtn = AddB("BLUE BLOCK", function(act)
    blockActive = act
    if blockActive then
        followPart = Instance.new("Part", workspace)
        followPart.Size, followPart.Transparency, followPart.Color, followPart.Anchored = Vector3.new(12,1,12), 0.6, Color3.fromRGB(0, 120, 255), true
    else
        if followPart then followPart:Destroy() end
    end
end)

AddB("SPIN BOT", function(s) spinActive = s end)

RunService.RenderStepped:Connect(function()
    UpdateESP()
    if blockActive and followPart and Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
        followPart.CFrame = Player.Character.HumanoidRootPart.CFrame * CFrame.new(0, -3.5, 0)
    end
end)

RunService.Stepped:Connect(function()
    local char = Player.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        local hrp, hum = char.HumanoidRootPart, char:FindFirstChildOfClass("Humanoid")
        if antiRagdollActive then
            hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
            hum:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
        end
        if speedActive and hum.MoveDirection.Magnitude > 0 then
            hrp.CFrame = hrp.CFrame + (hum.MoveDirection * (22/50))
        end
        if spinActive then hrp.CFrame = hrp.CFrame * CFrame.Angles(0, math.rad(55), 0) end
    end
end)

local Close = Instance.new("TextButton", Main)
Close.Size, Close.Position, Close.Text = UDim2.new(0, 35, 0, 35), UDim2.new(1, -40, 0, 5), "X"
Close.BackgroundColor3, Close.TextColor3 = Color3.fromRGB(150, 0, 0), Color3.fromRGB(255, 255, 255)
Instance.new("UICorner", Close)
Close.MouseButton1Click:Connect(function() 
    if followPart then followPart:Destroy() end 
    for _, box in pairs(espBoxes) do box:Remove() end
    ScreenGui:Destroy() 
end)

if Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
    savedCFrame = Player.Character.HumanoidRootPart.CFrame
    Player.Character:BreakJoints()
end
Player.CharacterAdded:Connect(ApplyGodMode)

