local Player = game:GetService("Players").LocalPlayer
local RunService = game:GetService("RunService")
local UIS = game:GetService("UserInputService")
local PlayerGui = Player:WaitForChild("PlayerGui")
local Players = game:GetService("Players")
local Lighting = game:GetService("Lighting")

local savedCFrame = nil
local speedActive = false
local blockActive = false
local spinActive = false
local infJumpActive = false
local antiRagdollActive = false
local espActive = false
local followPart = nil
local espBoxes = {}

local function ApplyGodMode(char)
    local hum = char:WaitForChild("Humanoid")
    RunService.Stepped:Connect(function()
        if char and hum and hum.Parent then
            hum.MaxHealth = 9e9
            hum.Health = 9e9
        end
    end)
end

local function OptimizeFPS(enable)
    if enable then
        settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
        for _, v in pairs(game:GetDescendants()) do
            if v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Fire") or v:IsA("Smoke") then
                v.Enabled = false
            end
        end
         Lighting.GlobalShadows = false
    else
        Lighting.GlobalShadows = true
    end
end

local function CreateESP(targetPlayer)
    if targetPlayer == Player then return end
    local box = Drawing.new("Square")
    box.Visible = false
    box.Color = Color3.fromRGB(255, 255, 255)
    box.Thickness = 1
    box.Filled = false
    espBoxes[targetPlayer] = box
end

local function UpdateESP()
    for targetPlayer, box in pairs(espBoxes) do
        if espActive and targetPlayer.Character and targetPlayer.Character:FindFirstChild("HumanoidRootPart") then
            local pos, onScreen = workspace.CurrentCamera:WorldToViewportPoint(targetPlayer.Character.HumanoidRootPart.Position)
            if onScreen then
                local size = Vector2.new(1000 / pos.Z, 1500 / pos.Z)
                box.Size = size
                box.Position = Vector2.new(pos.X - size.X / 2, pos.Y - size.Y / 2)
                box.Visible = true
            else box.Visible = false end
        else box.Visible = false end
    end
end

for _, p in pairs(Players:GetPlayers()) do CreateESP(p) end
Players.PlayerAdded:Connect(CreateESP)

if PlayerGui:FindFirstChild("StealASolitaktak") then PlayerGui.StealASolitaktak:Destroy() end
local ScreenGui = Instance.new("ScreenGui", PlayerGui)
ScreenGui.Name = "StealASolitaktak"
ScreenGui.ResetOnSpawn = false

