local function AddButton(name, callback, specialColor)
    local btn = Instance.new("TextButton", ScrollFrame)
    btn.Size = UDim2.new(0.9, 0, 0, 45)
    btn.BackgroundColor3 = specialColor or Color3.fromRGB(45, 45, 45)
    btn.Text = name
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.SourceSansBold
    btn.TextSize = 15
    Instance.new("UICorner", btn)

    local active = false
    btn.MouseButton1Click:Connect(function()
        active = not active
        if not specialColor then
            btn.BackgroundColor3 = active and Color3.fromRGB(0, 150, 80) or Color3.fromRGB(45, 45, 45)
        end
        callback(active)
    end)
end

